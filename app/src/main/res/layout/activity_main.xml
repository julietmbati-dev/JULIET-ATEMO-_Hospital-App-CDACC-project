<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="25dp"
    android:paddingTop="50dp"
    android:background="#F4F7F6">

    <!-- Title for the screen -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hospital Service Request"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#005792"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Service Type:"
        android:textSize="14sp"
        android:layout_marginBottom="5dp"/>

    <Spinner
        android:id="@+id/spinnerServices"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:entries="@array/services_array"
        android:background="@android:drawable/btn_dropdown"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/etWard"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Ward Number"
        android:inputType="number"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"
        android:layout_marginBottom="15dp" />

    <EditText
        android:id="@+id/etBed"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Bed Number"
        android:inputType="number"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"
        android:layout_marginBottom="15dp" />

    <EditText
        android:id="@+id/etNotes"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="Additional Notes (Optional)"
        android:gravity="top"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"
        android:inputType="textMultiLine"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="SUBMIT REQUEST"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#005792" />

</LinearLayout>